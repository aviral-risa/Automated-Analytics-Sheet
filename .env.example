# =============================================================================
# Environment variables — copy this file to .env and fill in values.
# Never commit .env to git.
# =============================================================================

# --- Google Sheets destination ---
# Spreadsheet ID from URL: https://docs.google.com/spreadsheets/d/<ID>/edit
DASHBOARD_SPREADSHEET_ID=

# --- Service account (needs BigQuery Data Viewer + Sheets Editor) ---
# Create at: GCP Console → IAM → Service Accounts → Keys → JSON
# Share the target Google Sheet with this email as Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: path to JSON key file instead of email/key above
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa.json

# --- BigQuery (optional overrides — defaults come from config/dashboard.config.ts) ---
# BIGQUERY_PROJECT_ID=prior--backen-prod-svc-u4g8
